---
import '../styles/global.css';
type Props = { title?: string; description?: string };
const { title = 'ОГИБДД-П — информационный раздел', description = 'Информационный раздел ОГИБДД-П: экипировка, бинды, доклады, автопарк и посты.' } = Astro.props;
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body><slot /></body>
</html>
