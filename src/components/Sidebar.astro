---
import Icon from './Icon.astro';
import type { NavigationItem } from '../data/navigation';
type Props = { items: NavigationItem[] };
const { items } = Astro.props;
---
<aside class="sidebar" aria-label="Навигация по справочнику">
  <a class="brand" href="#top" aria-label="ОГИБДД-П — в начало">
    <span class="brand-mark"><img src="https://i.imgur.com/P4ei9ra.png" alt="Логотип ОГИБДД-П" data-brand-image /><span class="brand-fallback is-hidden"><Icon name="badge" size={21} /></span></span>
    <span><strong>ОГИБДД-П</strong><small>информационный раздел</small></span>
  </a>
  <div class="sidebar-rule"></div>
  <div class="nav-label">Разделы</div>
  <nav class="side-nav">
    {items.map((item) => (
      <div class="nav-group" data-nav-group={item.id}>
        <div class="nav-parent"><a href={`#${item.id}`} data-nav-link={item.id} aria-current={item.id === 'leadership' ? 'true' : undefined}>
          <span class="nav-icon"><Icon name={item.id === 'rules' ? 'book' : item.id === 'binds' ? 'command' : item.id === 'reports' ? 'radio' : item.id === 'autopark' ? 'car' : item.id === 'posts' ? 'map' : item.id === 'callsigns' ? 'badge' : 'help'} size={16} /></span>
          <span class="nav-copy"><span>{item.label}</span></span>
        </a>{item.children && <button class="nav-toggle" type="button" data-nav-toggle aria-expanded={item.id === 'leadership' ? 'true' : 'false'} aria-label={`Раскрыть подразделы: ${item.label}`}><Icon name="chevron" size={15} /></button>}</div>
        {item.children && <div class={`side-subnav ${item.id !== 'leadership' ? 'is-collapsed' : ''}`}>{item.children.map((child) => <a href={`#${child.id}`} data-subnav-link>{child.label}</a>)}</div>}
      </div>
    ))}
  </nav>
</aside>
