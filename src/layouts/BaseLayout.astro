---
import '../styles/global.css';
type Props = { title?: string; description?: string };
const { title = 'ОГИБДД-П — информационный раздел', description = 'Информационный раздел ОГИБДД-П: экипировка, бинды, доклады, автопарк и посты.' } = Astro.props;
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%2313161a'/%3E%3Cpath d='M16 5 8 8v6c0 5 3.2 9.5 8 11 4.8-1.5 8-6 8-11V8l-8-3Z' fill='none' stroke='%2399b9d4' stroke-width='2'/%3E%3C/svg%3E" />
    <title>{title}</title>
  </head>
  <body><slot /></body>
</html>
