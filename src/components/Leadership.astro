---
import LeadershipCard from './LeadershipCard.astro';

type Person = { id: string; name: string; position: string; rank?: string; vacant?: boolean };
type OrgColumn = { id: string; label: string; chain: Person[]; branches?: Person[][] };

const chief: Person = {
  id: 'german-voronin',
  name: 'German_Voronin',
  position: 'Начальник ДПС',
  rank: 'Генерал-майор полиции',
};

const columns: OrgColumn[] = [
  {
    id: 'okn', label: 'Отдел кадрового надзора', chain: [
      { id: 'denis-kingsman', name: 'Denis_Kingsman', position: 'Начальник ОКН / заместитель начальника ДПС', rank: 'Полковник В.С.' },
      { id: 'vladimir-kotik', name: 'Vladimir_Kotik', position: 'Заместитель начальника ОКН', rank: 'Подполковник В.С.' },
      { id: 'egor-schneiderhan', name: 'Egor_Schneiderhan', position: 'Инспектор ОКН', rank: 'Майор В.С.' },
    ],
  },
  {
    id: 'osr', label: 'Отдельная специальная рота', chain: [
      { id: 'karl-daimler', name: 'Karl_Daimler', position: 'Командир ОСР', rank: 'Полковник полиции' },
      { id: 'egor-dashchonok', name: 'Egor_Dashchonok', position: 'Заместитель командира ОСР', rank: 'Подполковник полиции' },
      { id: 'osr-vacant', name: 'Не назначен', position: 'Старший инспектор по ОП', vacant: true },
    ],
  },
  {
    id: 'ob', label: 'Отдельный батальон', chain: [
      { id: 'ilia-vladimirov', name: 'Ilia_Vladimirov', position: 'Командир ОБ', rank: 'Полковник полиции' },
      { id: 'nikolay-kitonov', name: 'Nikolay_Kitonov', position: 'Заместитель командира ОБ', rank: 'Подполковник полиции' },
    ], branches: [
      [{ id: 'dmitriy-soldatikov', name: 'Dmitriy_Soldatikov', position: 'Командир первого взвода', rank: 'Майор полиции' }],
      [{ id: 'ob-vacant', name: 'Не назначен', position: 'Командир второго взвода', rank: 'Майор полиции', vacant: true }],
    ],
  },
  {
    id: 'cps', label: 'Центр профессиональной подготовки', chain: [
      { id: 'albert-vorobyev', name: 'Albert_Vorobyev', position: 'Начальник ЦПС', rank: 'Полковник полиции' },
    ], branches: [
      [
        { id: 'ivan-lambert', name: 'Ivan_Lambert', position: 'Начальник УК — учебного корпуса', rank: 'Подполковник полиции' },
        { id: 'artemiy-baranov', name: 'Artemiy_Baranov', position: 'Куратор УК', rank: 'Майор полиции' },
      ],
      [{ id: 'cps-vacant', name: 'Не назначен', position: 'Начальник СК', rank: 'Подполковник полиции', vacant: true }],
    ],
  },
  {
    id: 'oiios', label: 'Отдел информирования', chain: [
      { id: 'oiios-vacant', name: 'Не назначен', position: 'Начальник ОИиОС', rank: 'Подполковник В.С.', vacant: true },
    ],
  },
];
---

<div class="org-chart" id="leadership-tree" data-nav-target>
  <div class="org-root">
    <LeadershipCard person={chief} />
    <span class="org-root-stem" aria-hidden="true"></span>
  </div>

  <div class="org-main-rail" aria-hidden="true">
    {columns.map(() => <span></span>)}
  </div>

  <div class="org-columns">
    {columns.map((column) => (
      <section class={`org-column org-column-${column.id}`} aria-label={column.label}>
        <div class="org-chain">
          {column.chain.map((person) => <LeadershipCard person={person} />)}
        </div>

        {column.branches && (
          <div class="org-branches">
            {column.branches.map((branch) => (
              <div class="org-branch">
                {branch.map((person) => <LeadershipCard person={person} />)}
              </div>
            ))}
          </div>
        )}
      </section>
    ))}
  </div>
</div>
